#!/usr/bin/env python3
from PyPDF2 import PdfMerger

def merge_pdfs():
    # List your three source PDFs here:
    input_files = [
        r"C:\Users\adams\Downloads\page1.pdf",
        r"C:\Users\adams\Downloads\page2.pdf",
        r"C:\Users\adams\Downloads\page3.pdf",
    ]
    # Path for the merged output:
    output_file = r"C:\Users\adams\Downloads\combined.pdf"

    merger = PdfMerger()
    for pdf in input_files:
        merger.append(pdf)
    merger.write(output_file)
    merger.close()

    print(f"✅ Merged {len(input_files)} files into:\n   {output_file}")

if __name__ == "__main__":
    merge_pdfs()
