
import PyPDF2


input_files = "C:/Users/adams/Downloads/file1.pdf", "C:/Users/adams/Downloads/file2.pdf"
def combine_pdfs(input_files, output_file):
    pdf_writer = PyPDF2.PdfWriter()

    for file_name in input_files:
        try:
            with open(file_name, 'rb') as file:
                pdf_reader = PyPDF2.PdfReader(file)
                for page_num in range(len(pdf_reader.pages)):
                    pdf_writer.add_page(pdf_reader.pages[page_num])
        except Exception as e:
            print(f"Error reading {file_name}: {e}")

    try:
        with open(output_file, 'wb') as out_file:
            pdf_writer.write(out_file)
        print(f"Combined PDF saved to: {output_file}")
    except Exception as e:
        print(f"Error saving the combined PDF: {e}")

# Specify the input PDF files
pdf_files = [
    'C:/Users/adams/Downloads/file1.pdf', 
    'C:/Users/adams/Downloads/file2.pdf'
]

# Specify the output file path
output = 'C:/Users/adams/Downloads/combined_output.pdf'

# Call the function
combine_pdfs(pdf_files, output)
